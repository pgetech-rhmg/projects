
  {
    "Version":"2008-10-17",
    "Statement":[
      {
          "Effect":"Allow",
          "Principal": {
            "AWS": [
                "arn:aws:iam::${account_num}:role/${aws_role}"
            ]
       },
          "Action":[
           "s3:GetObject"
          ],
          "Resource":[
            "arn:aws:s3:::${bucket_name}/*"
          ]
      }
   ]
  }  