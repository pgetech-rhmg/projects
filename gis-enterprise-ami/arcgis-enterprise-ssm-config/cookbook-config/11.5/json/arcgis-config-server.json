{
    "arcgis": {
        "run_as_user": "arcgis",
        "version": "11.5",
        "repository": {
            "archives": "/opt/software/archives",
            "setups": "/opt/software/setups"
        },
        "server": {
            "install_dir": "/opt",
            "install_system_requirements": true,
            "admin_username": "__SERVER_ADMIN_USERNAME__",
            "admin_password": "__SERVER_ADMIN_PASSWORD__",
            "authorization_file": "/opt/arcgis/licenses/11.5/server.prvc",
            "log_level": "WARNING",
            "enable_debug": false,
            "log_dir": "/opt/arcgis/server/usr/logs",
            "directories_root": "/mnt/arcgisserver",
            "config_store_type": "FILESYSTEM",
            "config_store_connection_string": "/mnt/arcgisserver/config-store",
            "soc_max_heap_size": 64,
            "services_dir_enabled": true,
            "system_properties": {
                "suspendedMachineUnregisterThreshold": -1,
                "machineSuspendThreshold": 60
            }
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::system]",
        "recipe[arcgis-enterprise::server]"
    ]
}
