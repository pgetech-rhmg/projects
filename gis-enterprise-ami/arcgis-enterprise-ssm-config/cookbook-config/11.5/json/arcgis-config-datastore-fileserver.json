{
    "arcgis": {
        "version": "11.5",
        "run_as_user": "arcgis",
        "fileserver": {
            "directories": [
                "/mnt/arcgisbackup",
                "/mnt/arcgisbackup/tilecache",
                "/mnt/arcgisbackup/relational"
            ],
            "shares": [
                "/mnt/arcgisbackup"
            ]
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::system]",
        "recipe[arcgis-enterprise::fileserver]"
    ]
}
