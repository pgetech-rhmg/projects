{
    "arcgis": {
        "version": "11.5",
        "run_as_user": "arcgis",
        "repository": {
            "archives": "/opt/software/archives",
            "setups": "/opt/software/setups"
        },
        "portal": {
            "hostname": "__PORTAL_HOSTNAME__",
            "hostidentifier": "__PORTAL_HOSTIDENTIFIER__",
            "install_dir": "/opt",
            "admin_username": "__PORTAL_ADMIN_USERNAME__",
            "admin_password": "__PORTAL_ADMIN_PASSWORD__",
            "admin_email": "__PORTAL_ADMIN_EMAIL__",
            "admin_full_name": "Administrator",
            "admin_description": "Initial account administrator",
            "security_question_index": 1,
            "security_question_answer": "__SECURITY_QUESTION_ANSWER__",
            "log_dir": "/opt/arcgis/portal/usr/arcgisportal/logs",
            "log_level": "WARNING",
            "enable_debug": false,
            "content_store_type": "fileStore",
            "content_store_provider": "FileSystem",
            "content_store_connection_string": "/mnt/arcgisportal/content",
            "object_store": "",
            "authorization_file": "/opt/arcgis/licenses/11.5/portal.json",
            "user_license_type_id": "creatorUT",
            "install_system_requirements": true,
            "root_cert": "/opt/arcgis/ssl_certificate.pfx",
            "root_cert_alias": "portalpfx",
            "import_certificate_chain": true,
            "wa_name": "portal",
            "system_properties": {
                "privatePortalURL": "https://__PORTAL_PRIVATE_DOMAIN__:7443/arcgis",
                "WebContextURL": "https://__PORTAL_DOMAIN__/portal"
            }
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::portal]"
    ]
}
