{
    "arcgis": {
        "version": "11.5",
        "run_as_user": "arcgis",
        "repository": {
            "archives": "/opt/software/archives",
            "setups": "/opt/software/setups"
        },
        "server": {
            "admin_username": "__SERVER_ADMIN_USERNAME__",
            "admin_password": "__SERVER_ADMIN_PASSWORD__",
            "url": "https://__SERVER_DOMAIN__:6443/arcgis"
        },
        "data_store": {
            "hostidentifier": "__DATA_STORE_HOSTIDENTIFIER__",
            "install_dir": "/opt/arcgis/datastore",
            "setup_options": "-f Relational",
            "install_system_requirements": true,
            "types": "relational,object",
            "preferredidentifier": "hostname",
            "data_dir": "/opt/arcgis/datastore/data",
            "relational": {
                "backup_type": "fs",
                "backup_location": "/opt/arcgis/datastore/backup/relational",
                "disk_threshold_readonly": 5120,
                "max_connections": 150,
                "pitr": "disable",
                "enablessl": true
            },
            "object": {
                "backup_type": "fs",
                "backup_location": "/opt/arcgis/datastore/backup/object"
                }
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::system]",
        "recipe[arcgis-enterprise::datastore]"
    ]

}
