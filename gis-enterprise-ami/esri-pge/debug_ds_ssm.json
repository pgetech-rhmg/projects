{
  "schemaVersion": "2.2",
  "description": "Configure ArcGIS Data Stores site using cinc-client (multi-step, per-step logging + waits)",
  "parameters": {
    "dataStore": { "type": "String" }
  },
  "mainSteps": [

    {
      "action": "aws:runShellScript",
      "name": "prepSystem",
      "inputs": {
        "runCommand": [
          "#!/bin/bash",
          "set -euxo pipefail",
          "",
          "LOG_DIR=/var/log/datastore-config",
          "mkdir -p \"$LOG_DIR\"",
          "exec > >(tee -a \"$LOG_DIR/prepSystem.log\") 2>&1",
          "echo \"=== prepSystem: starting at $(date) ===\"",
          "",
          "sudo yum update -y || true",
          "sudo yum install -y amazon-ssm-agent ruby wget git unzip dmidecode --nogpgcheck || true",
          "systemctl enable amazon-ssm-agent || true",
          "systemctl start amazon-ssm-agent || true",
          "",
          "echo \"=== prepSystem: finished at $(date) ===\""
        ]
      }
    },

    {
      "action": "aws:runShellScript",
      "name": "installCinc",
      "inputs": {
        "runCommand": [
          "#!/bin/bash",
          "set -euxo pipefail",
          "",
          "LOG_DIR=/var/log/datastore-config",
          "mkdir -p \"$LOG_DIR\"",
          "exec > >(tee -a \"$LOG_DIR/installCinc.log\") 2>&1",
          "echo \"=== installCinc: starting at $(date) ===\"",
          "",
          "curl -L https://omnitruck.cinc.sh/install.sh | sudo bash -s -- -v 18.5.0",
          "export PATH=\"$PATH:/opt/cinc/bin\"",
          "mkdir -p /opt/cinc/cookbooks /opt/cinc/attributes /opt/cinc/cache",
          "git clone --depth 1 https://github.com/Esri/arcgis-cookbook.git /opt/cinc/temp",
          "mv /opt/cinc/temp/cookbooks/* /opt/cinc/cookbooks/ || true",
          "rm -rf /opt/cinc/temp || true",
          "",
          "echo \"=== installCinc: finished at $(date) ===\""
        ]
      }
    },

    {
      "action": "aws:runShellScript",
      "name": "runDataStoreConfig",
      "inputs": {
        "runCommand": [
          "#!/bin/bash",
          "set -euxo pipefail",
          "",
          "LOG_DIR=/var/log/datastore-config",
          "mkdir -p \"$LOG_DIR\"",
          "exec > >(tee -a \"$LOG_DIR/arcgis-datastore-primary.log\") 2>&1",
          "echo \"=== runDataStoreConfig: starting at $(date) ===\"",
          "",
          "echo '' | base64 --decode > /opt/cinc/attributes/arcgis-datastore-primary.json",
          "cinc-client -z -j /opt/cinc/attributes/arcgis-datastore-primary.json 2>&1 | tee -a \"$LOG_DIR/arcgis-datastore-primary.log\"",
          "RC=${PIPESTATUS[0]}",
          "if [ $RC -ne 0 ]; then echo \"Data Store cinc-client failed with exit $RC\" >&2; exit $RC; fi",
          "touch /var/run/data_store_done",
          "echo \"=== runDataStoreConfig: finished at $(date) ===\""
        ]
      }
    },

    {
      "action": "aws:runShellScript",
      "name": "waitForDataStore",
      "inputs": {
        "runCommand": [
          "#!/bin/bash",
          "set -euxo pipefail",
          "",
          "LOG_DIR=/var/log/datastore-config",
          "mkdir -p \"$LOG_DIR\"",
          "exec > >(tee -a \"$LOG_DIR/waitForDataStore.log\") 2>&1",
          "echo \"Waiting for data_store_done marker...\"",
          "COUNT=0",
          "while [ ! -f /var/run/data_store_done ]; do",
          "  sleep 5",
          "  COUNT=$((COUNT+1))",
          "  if [ $COUNT -ge 720 ]; then echo 'Timed out waiting for data_store_done' >&2; exit 1; fi",
          "done",
          "echo \"data_store_done found, continuing.\""
        ]
      }
    }

  ]
}
