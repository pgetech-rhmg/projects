# Local development configuration
# Copy this to .env and fill in your values
# NEVER commit .env to source control

CONFLUENCE_BASE_URL=https://wiki.comp.pge.com
CONFLUENCE_ROOT_PAGE_IDS=your-root-page-ids-here
CONFLUENCE_SESSION_ID=your-JSESSIONID-value-here
CONFLUENCE_SERAPH=your-seraph.confluence-value-here
CONFLUENCE_MRH_SESSION=your-MRHSession-value-here

KB_PATH=./knowledge_base.json
VERIFY_SSL=false