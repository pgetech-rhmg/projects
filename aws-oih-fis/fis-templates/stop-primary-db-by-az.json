{
  "description": "FIS Experiment: Stop Primary SQL Server instances in target AZ (with strict tag-based safety controls)",
  "targets": {
    "primaryDBInstancesInTargetAZ": {
      "resourceType": "aws:ec2:instance",
      "selectionMode": "ALL",
      "resourceTags": {
        "FISTarget": "True",
        "FISDBRole": "Primary"
      },
      "filters": [
        {
          "path": "State.Name",
          "values": ["running"]
        },
        {
          "path": "Placement.AvailabilityZone",
          "values": ["RUNTIME_PARAMETER_AZ"]
        }
      ]
    }
  },
  "actions": {
    "stopPrimaryDBInstances": {
      "actionId": "aws:ec2:stop-instances-v2",
      "description": "Stop primary SQL Server instances in target AZ to simulate AZ failure",
      "parameters": {
        "duration": "PT5M"
      },
      "targets": {
        "Instances": "primaryDBInstancesInTargetAZ"
      }
    }
  },
  "stopConditions": [
    {
      "source": "none"
    }
  ],
  "roleArn": "ROLE_ARN_PLACEHOLDER",
  "tags": {
    "Name": "OIH-Primary-DB-AZ-Failure-Stop",
    "Environment": "DEV",
    "TestType": "HA-DR",
    "Component": "SQL-Server-Primary",
    "TestScenario": "Primary-Failover"
  },
  "logConfiguration": {
    "cloudWatchLogsConfiguration": {
      "logGroupArn": "LOG_GROUP_ARN_PLACEHOLDER"
    },
    "logSchemaVersion": 2
  }
}
