{
  "description": "FIS Experiment: Stop Secondary SQL Server instances in non-primary AZ (with strict tag-based safety controls)",
  "targets": {
    "secondaryDBInstancesInTargetAZ": {
      "resourceType": "aws:ec2:instance",
      "selectionMode": "ALL",
      "resourceTags": {
        "FISTarget": "True",
        "FISDBRole": "Secondary"
      },
      "filters": [
        {
          "path": "State.Name",
          "values": ["running"]
        },
        {
          "path": "Placement.AvailabilityZone",
          "values": ["RUNTIME_PARAMETER_AZ"]
        }
      ]
    }
  },
  "actions": {
    "stopSecondaryDBInstances": {
      "actionId": "aws:ec2:stop-instances-v2",
      "description": "Stop secondary SQL Server instances in target AZ to test primary stability",
      "parameters": {
        "duration": "PT5M"
      },
      "targets": {
        "Instances": "secondaryDBInstancesInTargetAZ"
      }
    }
  },
  "stopConditions": [
    {
      "source": "none"
    }
  ],
  "roleArn": "ROLE_ARN_PLACEHOLDER",
  "tags": {
    "Name": "OIH-Secondary-DB-AZ-Failure-Stop",
    "Environment": "DEV",
    "TestType": "HA-DR",
    "Component": "SQL-Server-Secondary",
    "TestScenario": "Secondary-Isolation"
  },
  "logConfiguration": {
    "cloudWatchLogsConfiguration": {
      "logGroupArn": "LOG_GROUP_ARN_PLACEHOLDER"
    },
    "logSchemaVersion": 2
  }
}
