{
    "Version": "2012-10-17",
    "Statement": [
    {
    "Effect": "Allow",
    "Action": [
       "dynamodb: *"
      ],
    "Resource": "*"
    },
    {
        "Effect": "Allow",
        "Action": [
            "ssm:PutParameter",
            "ssm:GetParameters"
        ],
        "Resource": "arn:aws:ssm:*:*:parameter/CodeBuild/*"
    }
    ]
    }