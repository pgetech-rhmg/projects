{
    "Version": "2012-10-17",
    "Statement": [
    {
    "Effect": "Allow",
    "Action": [
        "cloudwatch:List*",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "ec2:*",
        "logs:GetLogEvents",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:CreateLogGroup",
        "codecommit:GetBranch",
        "codecommit:GetCommit",
        "codecommit:GetRepository",
        "codecommit:ListBranches",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutObject"
      ],
    "Resource": "*"
    },
    {
        "Effect": "Allow",
        "Action": [
            "ssm:PutParameter",
            "ssm:GetParameters"
        ],
        "Resource": "arn:aws:ssm:*:*:parameter/CodeBuild/*"
    },
    {
        "Effect": "Allow",
        "Action": [
            "kms:DescribeKey",
            "kms:CreateCustomKeyStore",
            "kms:DescribeCustomKeyStores",
            "kms:CreateKey",
            "kms:List*",
            "kms:GetKeyPolicy",
            "kms:UpdatePrimaryRegion",
            "kms:ConnectCustomKeyStore",
            "kms:GenerateDataKey",
            "kms:GenerateDataKeyPair",
            "kms:SynchronizeMultiRegionKey",
            "kms:ReplicateKey",
            "kms:Encrypt",
            "kms:Decrypt",
            "kms:GetKeyPolicy"
        ],
        "Resource": [
            "${s3_kms_key_arn}"
        ]
    }
    ]
}