{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": [
                "kms:DescribeKey",
                "kms:CreateCustomKeyStore",
                "kms:DescribeCustomKeyStores",
                "kms:CreateKey",
                "kms:List*",
                "kms:UpdatePrimaryRegion",
                "kms:ConnectCustomKeyStore",
                "kms:GenerateDataKey",
                "kms:GenerateDataKeyPair",
                "kms:SynchronizeMultiRegionKey",
                "kms:ReplicateKey",
                "kms:Encrypt",
                "kms:Decrypt",
                "kms:GetKeyPolicy"
            ],
            "Resource": [
                "arn:aws:kms:us-west-2:*:key/*"
            ]
        },
        {
            "Effect": "Allow",
            "Action": [
                "organizations:ListAccountsForParent",
                "organizations:ListOrganizationalUnitsForParent"
            ],
            "Resource": [
                "arn:aws:organizations::956254777756:root/o-3dot1zcpsr/r-nfqe",
                "arn:aws:organizations::956254777756:root/o-3dot1zcpsr/r-nfqe/*",
                "arn:aws:organizations::956254777756:ou/o-3dot1zcpsr/*"
            ]
        },
        {
            "Effect": "Allow",
            "Action": "sts:AssumeRole",
            "Resource": "arn:aws:iam::*:role/IAMPipelineRole"
        }
    ]
}