{
    "Version": "2012-10-17",
    "Id": "AWSLogDeliveryWrite",
    "Statement": [
        {
            "Sid": "AWSLogDeliveryAclCheck",
            "Effect": "Allow",
            "Principal": {
                "Service": "delivery.logs.amazonaws.com"
            },
            "Action": "s3:GetBucketAcl",
            "Resource": "arn:aws:s3:::${bucket_name}",
            "Condition": {
                "StringEquals": {
                    "aws:SourceAccount": ["${account_num}"]
                },
                "ArnLike": {
                    "aws:SourceArn": ["arn:aws:logs:${aws_region}:${account_num}:*"]
                }
            }
        },
        {
            "Sid": "AWSLogDeliveryWrite",
            "Effect": "Allow",
            "Principal": {
                "Service": "delivery.logs.amazonaws.com"
            },
            "Action": "s3:PutObject",
            "Resource": "arn:aws:s3:::${bucket_name}/*",
            "Condition": {
                "StringEquals": {
                    "s3:x-amz-acl": "bucket-owner-full-control",
                    "aws:SourceAccount": ["${account_num}"]
                },
                "ArnLike": {
                    "aws:SourceArn": ["arn:aws:logs:${aws_region}:${account_num}:*"]
                }
            }
        }
    ]
}