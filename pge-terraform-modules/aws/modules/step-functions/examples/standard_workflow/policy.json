{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "Service" : "logs.amazonaws.com"
            },
            "Action": [
                "kms:Encrypt",
                "kms:Decrypt",
                "kms:GenerateDatakey"
              
            ],
            "Resource": [
                "*",
               "${cloudwatch_log_name_prefix}"
            ]
        }
    ]
}