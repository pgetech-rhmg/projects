{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "API Gateway IAM role to allow use of the key",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::${account_num}:role/${apigw_role}"
                ]
            },
            "Action": [
                "kms:GenerateDataKey",
                "kms:Decrypt"
            ],
            "Resource": "*"
        }
    ]
}