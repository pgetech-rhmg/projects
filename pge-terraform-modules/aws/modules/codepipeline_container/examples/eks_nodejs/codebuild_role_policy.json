{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ],
        "Resource": [
          "arn:${partition}:logs:${aws_region}:${account_num}:log-group:/aws/codebuild/${codebuild_project_name}",
          "arn:${partition}:logs:${aws_region}:${account_num}:log-group:/aws/codebuild/${codebuild_project_name}:*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:GetObjectVersion",
          "s3:PutObject"
        ],
        "Resource": [
          "arn:${partition}:s3:::s3-${codepipeline_name}/*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:${partition}:s3:::s3-${codepipeline_name}"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "secretsmanager:GetSecretValue"
        ],
        "Resource": [
          "arn:${partition}:secretsmanager:${aws_region}:${account_num}:secret:${github_token_secret_name}*",
          "arn:${partition}:secretsmanager:${aws_region}:${account_num}:secret:${shared_argocd_github_pat_secret_name}*",
          "arn:${partition}:secretsmanager:${aws_region}:${account_num}:secret:${jfrog_credentials_secret_name}*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "ssm:GetParameter",
          "ssm:GetParameters"
        ],
        "Resource": [
          "arn:${partition}:ssm:${aws_region}:${account_num}:parameter/jfrog/*",
          "arn:${partition}:ssm:${aws_region}:${account_num}:parameter/vpc/*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
            "ec2:CreateNetworkInterface",
            "ec2:DescribeDhcpOptions",
            "ec2:DescribeNetworkInterfaces",
            "ec2:DeleteNetworkInterface",
            "ec2:DescribeSubnets",
            "ec2:DescribeSecurityGroups",
            "ec2:DescribeVpcs",
            "secretsmanager:GetSecretValue",
            "secretsmanager:DescribeSecret"
        ],
        "Resource": "*"
      },
      {
        "Effect": "Allow",
        "Action": [
          "ec2:CreateNetworkInterfacePermission"
        ],
        "Resource": [
        "arn:aws:ec2:${aws_region}:${account_num}:network-interface/*"
        ],
        "Condition": {
          "StringLike": {
            "ec2:Subnet": [
              "arn:aws:ec2:${aws_region}:${account_num}:subnet/*"
            ],
            "ec2:AuthorizedService": "codebuild.amazonaws.com"
          }
        }
      },
      {
        "Effect": "Allow",
        "Action": [
          "codebuild:CreateReportGroup",
          "codebuild:CreateReport",
          "codebuild:UpdateReport",
          "codebuild:BatchPutTestCases",
          "codebuild:BatchPutCodeCoverages"
        ],
        "Resource": [
          "arn:${partition}:codebuild:${aws_region}:${account_num}:report-group/${codebuild_project_name}-*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "iam:PassRole"
        ],
        "Resource": "*"
      },
      {
        "Effect": "Allow",
        "Action": [
          "eks:DescribeCluster",
          "eks:ListClusters"
        ],
        "Resource": "*"
      }
    ]
  }  