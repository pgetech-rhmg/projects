
  {
    "Version":"2008-10-17",
    "Statement":[
      
      {
        "Effect": "Allow",
        "Action": [
          "s3:ListBucket"        
        ],
        "Principal": {
          "AWS":  "arn:aws:iam::${account_num}:root"
        },
        "Resource": "arn:aws:s3:::${bucket_name}"
      },
      {
        "Effect": "Allow",
        "Action": [
          "s3:GetObject", 
          "s3:PutObject"
        ],
        "Principal": {
          "AWS": "arn:aws:iam::${account_num}:root"
        },
        "Resource": "arn:aws:s3:::${bucket_name}/*"
      }
   ]
  }  