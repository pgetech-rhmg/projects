{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "To perform kms GenerateDataKey",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::${account_num}:role/wiz_scanning_${codepipeline_name}_iam_role"
                ]
            },
            "Action": [
                "kms:DescribeKey",
                "kms:CreateCustomKeyStore",
                "kms:DescribeCustomKeyStores",
                "kms:CreateKey",
                "kms:List*",
                "kms:GetKeyPolicy",
                "kms:UpdatePrimaryRegion",
                "kms:ConnectCustomKeyStore",
                "kms:GenerateDataKey",
                "kms:GenerateDataKeyPair",
                "kms:SynchronizeMultiRegionKey",
                "kms:ReplicateKey",
                "kms:Encrypt",
                "kms:Decrypt"
            ],
            "Resource": "*"
        },
        {
            "Sid": "CCOE-TFE Allow ALL IAM user permission",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::${account_num}:root"
                ]
            },
            "Action": [
                "kms:DescribeKey",
                "kms:CreateCustomKeyStore",
                "kms:DescribeCustomKeyStores",
                "kms:CreateKey",
                "kms:List*",
                "kms:GetKeyPolicy",
                "kms:UpdatePrimaryRegion",
                "kms:ConnectCustomKeyStore",
                "kms:GenerateDataKey",
                "kms:GenerateDataKeyPair",
                "kms:SynchronizeMultiRegionKey",
                "kms:ReplicateKey",
                "kms:Encrypt",
                "kms:Decrypt"
            ],
            "Resource": "*"
        }
    ]
}