{
    "Version": "2012-10-17",
    "Statement": [
    {
    "Effect": "Allow",
    "Action": [
        "cloudwatch:List*",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "ec2:*",
        "logs:GetLogEvents",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:CreateLogGroup",
        "codecommit:GetBranch",
        "codecommit:GetCommit",
        "codecommit:GetRepository",
        "codecommit:ListBranches"
      ],
    "Resource": "*"
    },
    {
     "Action": [
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutObject"
       ],
       "Effect": "Allow",
       "Resource": "${codepipeline_bucket_arn}"
    },
    {
        "Effect": "Allow",
        "Action": [
            "ssm:PutParameter",
            "ssm:GetParameters"
        ],
        "Resource": "arn:aws:ssm:*:*:parameter/CodeBuild/*"
    }
    ]
    }
