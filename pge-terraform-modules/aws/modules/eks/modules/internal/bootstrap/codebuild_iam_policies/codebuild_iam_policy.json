{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "cloudwatch:List*",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "ec2:*",
        "logs:GetLogEvents",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:CreateLogGroup",
        "codecommit:GetBranch",
        "codecommit:GetCommit",
        "codecommit:GetRepository",
        "codecommit:ListBranches",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutObject",
        "eks:*",
        "ssm:GetParameter",
        "iam:GetRole",
        "iam:PassRole",
        "kms:Decrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetRandomPassword",
        "secretsmanager:GetResourcePolicy",
        "secretsmanager:GetSecretValue",
        "secretsmanager:ListSecretVersionIds",
        "secretsmanager:ListSecrets"
      ],
      "Resource": [
        "${codebuild_git_auth}",
        "${argocd_git_auth}",
        "arn:aws:secretsmanager:us-west-2:*:secret:shared-eks-wiz-creds-*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "ssm:PutParameter",        "ssm:GetParameters"
      ],
      "Resource": "arn:aws:ssm:*:*:parameter/CodeBuild/*"
    }
  ]
}