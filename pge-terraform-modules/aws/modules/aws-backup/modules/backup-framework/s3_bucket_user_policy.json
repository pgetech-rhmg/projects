{
  "Version": "2012-10-17",
  "Statement": [
      {
          "Effect": "Allow",
          "Principal": {
              "AWS": ["arn:aws:iam::${account_num}:role/${aws_role}"]
          },
          "Action": "s3:PutObject",
          "Resource": [
              "arn:aws:s3:::${bucket_name}/*"
          ],
          "Condition": {
              "StringEquals": {
                  "s3:x-amz-acl": "bucket-owner-full-control"
              }
          }
      }
  ]
}
