{
    "Version": "2012-10-17",
    "Id": "EFSSecureTransport",
    "Statement": [
        {
            "Sid": "EFSSecureTransport",
            "Effect": "Allow",
            "Principal": {
                "AWS": "*"
            },
            "Resource": "${efs_arn}",
            "Action": [
                "elasticfilesystem:ClientMount",
                "elasticfilesystem:ClientWrite",
                "elasticfilesystem:ClientRootAccess"
            ]
        },
        {
            "Sid": "EFSDenyNomSecureTransport",
            "Effect": "Deny",
            "Principal": {
                "AWS": "*"
            },
            "Resource": "${efs_arn}",
            "Action": "*",
            "Condition": {
                "Bool": {
                    "aws:SecureTransport": "false"
                }
            }
        }
    ]
}
