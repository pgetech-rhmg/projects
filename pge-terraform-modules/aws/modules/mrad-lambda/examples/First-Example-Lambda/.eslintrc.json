{
	"env": {
		"browser": true,
		"commonjs": true,
		"es6": true,
		"node": true
	},
	"plugins": ["prettier", "jest"],
	"extends": ["eslint:recommended", "prettier", "airbnb-base", "plugin:jest/recommended"],
	"globals": {
		"Atomics": "readonly",
		"SharedArrayBuffer": "readonly"
	},
	"parserOptions": {
		"ecmaVersion": "latest"
	},
	"rules": {
		"no-underscore-dangle": "off"
	}
}