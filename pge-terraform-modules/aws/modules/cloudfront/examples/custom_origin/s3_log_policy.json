{
  "Version": "2008-10-17",
  "Statement": [
      {
          "Sid": "Put bucket policy needed for audit logging",
          "Effect": "Allow",
          "Principal": {
              "Service": "cloudfront.amazonaws.com"
          },
          "Action": [
              "s3:PutObject",
              "s3:GetBucketAcl"
          ],
          "Resource": [
              "arn:aws:s3:::${bucket}",
              "arn:aws:s3:::${bucket}/*"
          ]
      }
  ]
}