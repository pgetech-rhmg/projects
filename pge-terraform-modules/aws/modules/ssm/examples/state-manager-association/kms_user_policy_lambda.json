{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "To perform kms GenerateDataKey",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::${account_num}:role/${kms_admins}"        
                
                ]
            },
            "Action": [
                "kms:GenerateDataKey"
            ],
            "Resource": "*"
        }
    ]
}