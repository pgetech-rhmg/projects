{
   "Version":"2008-10-17",
   "Statement":[
     {    
         "Sid":"Allow IAM user",
         "Effect":"Allow",
         "Principal": {
           "AWS": [
               "arn:aws:iam::${account_num}:role/${aws_role}"
           ]
      },
         "Action":[
          "s3:*"
         ],
         "Resource":[
           "arn:aws:s3:::${bucket_name}/*"
         ]
     }
  ]
 }  