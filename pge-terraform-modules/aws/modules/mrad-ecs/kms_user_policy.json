{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "CCOETFEAllowAllIAMUserPermissions",
            "Effect": "Allow",
            "Principal": {
                "AWS": "*"
            },
            "Action": [
                "kms:DescribeKey",
                "kms:CreateCustomKeyStore",
                "kms:DescribeCustomKeyStores",
                "kms:CreateKey",
                "kms:List*",
                "kms:GetKeyPolicy",
                "kms:UpdatePrimaryRegion",
                "kms:ConnectCustomKeyStore",
                "kms:GenerateDataKey",
                "kms:GenerateDataKeyPair",
                "kms:SynchronizeMultiRegionKey",
                "kms:ReplicateKey",
                "kms:Encrypt",
                "kms:Decrypt",
                "kms:GetKeyPolicy"
            ],
            "Resource": "*"
        }
    ]
}
