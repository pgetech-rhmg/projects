{
	"Version": "2012-10-17",
	"Statement": [{
			"Sid": "Allow IAM user permission",
			"Effect": "Allow",
			"Principal": {
				"AWS": [
					"arn:aws:iam::${account_num}:role/${ecs_iam}"
				]
			},
			"Action": "kms:*",
			"Resource": "*"
		},
		{
			"Effect": "Allow",
			"Principal": {
				"Service": "logs.${aws_region}.amazonaws.com"
			},
			"Action": [
				"kms:Encrypt*",
				"kms:Decrypt*",
				"kms:ReEncrypt*",
				"kms:GenerateDataKey*",
				"kms:Describe*"
			],
			"Resource": "*",
			"Condition": {
				"ArnEquals": {
					"kms:EncryptionContext:aws:logs:arn": "arn:aws:logs:${aws_region}:${account_num}:log-group:*"
				}
			}
		}
	]
}