{
  "Version": "2012-10-17",
  "Statement": [
      {
          "Sid": "Allow IAM user permission",
          "Effect": "Allow",
          "Principal": {
              "AWS": [
              "arn:aws:iam::${account_num}:role/${ecs_iam}"  
              ]
          },
          "Action": "kms:*",
          "Resource": "*"
      }        
          ]
}