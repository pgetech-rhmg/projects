{
  "Version": "2012-10-17",
  "Statement": [
      {
          "Sid": "Allow IAM user permission",
          "Effect": "Allow",
          "Principal": {
              "AWS": "arn:aws:iam::056672152820:role/TF_Developers"
          },
          "Action": "kms:*",
          "Resource": "*"
      },
      {
          "Sid": "Allow root access",
          "Effect": "Allow",
          "Principal": {
              "AWS": [
                  "arn:aws:iam::056672152820:role/SuperAdmin",
                  "arn:aws:iam::056672152820:role/CloudAdmin"
              ]
          },
          "Action": "kms:*",
          "Resource": "*"
      },
      {
          "Sid": "Allow IAM assume role access",
          "Effect": "Allow",
          "Principal": {
              "AWS": "arn:aws:iam::056672152820:role/CloudAdmin"
          },
          "Action": "kms:*",
          "Resource": "*"
      },
      {
          "Sid": "Allow access for Key Administrators",
          "Effect": "Allow",
          "Principal": {
              "AWS": "arn:aws:iam::056672152820:role/SecurityAdmin"
          },
          "Action": [
              "kms:Create*",
              "kms:Describe*",
              "kms:Enable*",
              "kms:List*",
              "kms:Put*",
              "kms:Update*",
              "kms:Revoke*",
              "kms:Disable*",
              "kms:Get*",
              "kms:Delete*",
              "kms:TagResource",
              "kms:UntagResource",
              "kms:ScheduleKeyDeletion",
              "kms:CancelKeyDeletion"
          ],
          "Resource": "*"
      }
  ]
}